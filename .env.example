# KHIPU Arqueo Pro v4.2 — Variables de entorno Backend (PostgreSQL / Supabase)

PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Base de datos ────────────────────────────────────────────────────────────
# Copia esta URL desde: Supabase → Settings → Database → Connection string → URI
# Reemplaza [TU-PASSWORD] con la contraseña que pusiste al crear el proyecto
DATABASE_URL=postgresql://postgres:[TU-PASSWORD]@db.XXXXXXXXXX.supabase.co:5432/postgres

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=khipu_secret_corporacion_2026
